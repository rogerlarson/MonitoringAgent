{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "LogDirectory": "Logs",
    "RetentionDays": 30,
    "CleanupIntervalHours": 24,
    "EnableApiLogging": true,
    "EnableHeartbeatLogging": true,
    "EnableAlertLogging": true,
    "EnableEmailLogging": true,
    "EnableMaintenanceLogging": true
  },
  "AgentSettings": {
    "CollectorUrl": "http://localhost:5037/api/health",
    "ApiKey": "my-super-secret-key",
    "PollIntervalSeconds": 5,
    "IgnitionServiceName": "Ignition",
    "GatewayUrl": "http://localhost:8088",
    "HttpTimeoutSeconds": 10,
    "MonitoredDrive": "C:",
    "NetworkInterfaceName": "Realtek Gaming 2.5GbE Family Controller",
    "IgnitionInstallPath": "C:\\Program Files\\Inductive Automation\\Ignition"
  }
}
