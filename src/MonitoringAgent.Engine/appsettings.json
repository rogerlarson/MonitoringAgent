{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "LogDirectory": "Logs",
    "RetentionDays": 30,
    "CleanupIntervalHours": 24,
    "EnableApiLogging": true,
    "EnableHeartbeatLogging": true,
    "EnableAlertLogging": true,
    "EnableEmailLogging": true,
    "EnableMaintenanceLogging": true
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MonitoringDatabase": "Server=localhost\\SQLEXPRESS;Database=MONITORING;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Email": {
    "Host": "localhost",
    "Port": 25,
    "EnableSsl": false,
    "UserName": "",
    "Password": "",
    "FromAddress": "server-monitoring-service@rtx.com",
    "ToAddress": "roger.andrew.larson@gmail.com"
  },
  "Monitoring": {
    "OfflineThresholdMinutes": 2,
    "RequireApiKey": true,
    "ApiKey": "my-super-secret-key"
  },
  "Engine": {
    "OfflineMonitorIntervalSeconds": 15,
    "AlertMonitorIntervalSeconds": 15,
    "SnapshotCleanupIntervalMinutes": 60,
    "LogCleanupIntervalHours": 24
  },
  "Retention": {
    "HostSnapshotDays": 30,
    "GatewaySnapshotDays": 30,
    "IgnitionSnapshotDays": 30,
    "AlertEventDays": 365
  }
}
